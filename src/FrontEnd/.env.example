# Google Calendar API config for EventCalendar
# 1. Create an API key at https://console.cloud.google.com/apis/credentials
#    (restrict it to the Google Calendar API; restrict referrers to your site)
# 2. Make the calendar public: Calendar settings -> "Access permissions" -> "Make available to public"
# 3. Copy the Calendar ID from Calendar settings -> "Integrate calendar"
# 4. Copy this file to .env and fill in the values

VITE_GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
VITE_GOOGLE_API_KEY=your-google-api-key
